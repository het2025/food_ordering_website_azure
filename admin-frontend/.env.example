# API Base URL for the admin backend
# For local development:
# VITE_API_URL=http://localhost:5002/api/admin
# For Azure production (replace with your actual Azure App Service URL):
VITE_API_URL=https://your-admin-backend-app.azurewebsites.net/api/admin

# Socket URL for real-time notifications (Restaurant Approvals etc.)
# Include the port if your backend listens on one, or just the domain if using standard HTTPS port
VITE_SOCKET_URL=https://your-restaurant-backend-url.azurewebsites.net
